# web_02 — variáveis de ambiente (exemplo). NÃO commitar .env real.
# Segredos via padrão _FILE (montados em /run/secrets em prod via Infisical/Vaultwarden).

# OIDC — Authentik (IdP único do deploy ACDG-BV)
AUTHENTIK_URL=https://auth.acdg-bv.org.br
AUTHENTIK_APP_SLUG=acdg-web
OIDC_CLIENT_ID=acdg-web
OIDC_CLIENT_SECRET_FILE=./.secrets/oidc_client_secret

# Sessão (assinatura do cookie opaco)
SESSION_SECRET_FILE=./.secrets/session_secret

# Redis (Bun.redis) — store de sessão server-side (ADR-0005)
REDIS_URL=redis://localhost:6379

# Base pública (para montar redirect_uri do OIDC)
PUBLIC_BASE_URL=http://localhost:3000
