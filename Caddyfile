# Caddyfile — Local development reverse proxy with auto-TLS.
# Caddy generates a self-signed certificate for localhost automatically.
# Browser accesses https://localhost → Caddy terminates TLS → http://bff:8081

https://localhost {
	reverse_proxy bff:8081

	# Pass the original host and protocol to the BFF
	header_up X-Forwarded-Proto {scheme}
	header_up X-Forwarded-Host {host}
}
