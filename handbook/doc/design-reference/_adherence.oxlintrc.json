{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data-display/**",
              "components/dataviz/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/analysis-bi/**",
              "ui_kits/people-context/**",
              "ui_kits/social-care/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Atkinson Hyperlegible Next|Atkinson Hyperlegible Mono|Atkinson Hyperlegible))/i]",
        "message": "Font not provided by the design system. Available: Atkinson Hyperlegible Next, Atkinson Hyperlegible Mono, Atkinson Hyperlegible."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgePyramidItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:ageBand|sex|value|key|ref|className|style|children)$/]",
        "message": "<AgePyramidItem> doesn't accept that prop. Declared props: ageBand, sex, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgePyramidItem'] > JSXAttribute[name.name='sex'] > Literal[value!=/^(?:MALE|FEMALE|UNKNOWN)$/]",
        "message": "<AgePyramidItem> sex must be one of 'MALE' | 'FEMALE' | 'UNKNOWN'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IdpRetryBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:onRetry|isPending|error|key|ref|className|style|children)$/]",
        "message": "<IdpRetryBanner> doesn't accept that prop. Declared props: onRetry, isPending, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='LgpdAnonymizedBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|key|ref|className|style|children)$/]",
        "message": "<LgpdAnonymizedBanner> doesn't accept that prop. Declared props: message."
