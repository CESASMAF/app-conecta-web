{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "prototype-server",
      "runtimeExecutable": "deno",
      "runtimeArgs": ["run", "--allow-net", "--allow-read", "jsr:@std/http@1/file-server", "--port", "3000"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "bff-dev",
      "runtimeExecutable": "deno",
      "runtimeArgs": ["run", "--allow-net", "--allow-env", "--allow-read", "--env", "src/server.ts"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "docker-compose",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 8081,
      "autoPort": false
    }
  ]
}
