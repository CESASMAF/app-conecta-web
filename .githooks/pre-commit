#!/bin/bash
# Pre-commit hook: blocks commits to main/master and runs basic checks.
# Install: git config core.hooksPath .githooks

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# ── Block direct commits to main ────────────────────────────────────────────
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  ❌  BLOQUEADO: Commit direto na branch '$BRANCH'       ║"
  echo "║                                                          ║"
  echo "║  Crie uma branch antes de commitar:                      ║"
  echo "║    git checkout -b feat/minha-feature                    ║"
  echo "║    git checkout -b fix/meu-fix                           ║"
  echo "║    git checkout -b ui/minha-mudanca                      ║"
  echo "║                                                          ║"
  echo "║  Depois faça PR para main.                               ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ── Block commits with .env or secrets ──────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only)

if echo "$STAGED_FILES" | grep -qE '\.env$|\.env\.local|\.env\.production|\.env\.staging'; then
  echo ""
  echo "❌  BLOQUEADO: Tentativa de commitar arquivo .env"
  echo "   Arquivos .env contêm secrets e NÃO devem ser commitados."
  echo ""
  exit 1
fi

# ── Enforce branch naming convention ────────────────────────────────────────
if ! echo "$BRANCH" | grep -qE '^(feat|fix|ui|proto|chore|docs|refactor|test)/'; then
  echo ""
  echo "⚠️  Branch '$BRANCH' não segue a convenção."
  echo "   Use: feat/, fix/, ui/, chore/, docs/, refactor/, test/"
  echo "   Exemplo: ui/melhorar-home-page"
  echo ""
  # Warning only, not blocking
fi

# ── Enforce scope for ui/* branches (designer) ─────────────────────────────
if echo "$BRANCH" | grep -qE '^ui/'; then
  ALLOWED_PATTERN='^src/client/views/|^src/client/styles/|^src/views/|^static/|^prototypes/'
  FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -vE "$ALLOWED_PATTERN" | grep -vE '^[[:space:]]*$')

  if [ -n "$FORBIDDEN_FILES" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  ❌  BLOQUEADO: Branch ui/* — escopo restrito            ║"
    echo "║                                                          ║"
    echo "║  Arquivos permitidos:                                    ║"
    echo "║    src/client/views/   src/client/styles/                ║"
    echo "║    src/views/          static/       prototypes/         ║"
    echo "║                                                          ║"
    echo "║  Arquivos fora do escopo:                                ║"
    echo "$FORBIDDEN_FILES" | while read -r f; do echo "║    $f"; done
    echo "║                                                          ║"
    echo "║  Se precisar modificar outros arquivos, peça ao dev.     ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
fi

# ── Enforce scope for proto/* branches (prototypes only) ───────────────────
if echo "$BRANCH" | grep -qE '^proto/'; then
  ALLOWED_PATTERN='^prototypes/'
  FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -vE "$ALLOWED_PATTERN" | grep -vE '^[[:space:]]*$')

  if [ -n "$FORBIDDEN_FILES" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  ❌  BLOQUEADO: Branch proto/* — apenas prototypes/      ║"
    echo "║                                                          ║"
    echo "║  Coloque prototipos HTML em: prototypes/                 ║"
    echo "║  Nunca na raiz do projeto.                               ║"
    echo "║                                                          ║"
    echo "║  Arquivos fora do escopo:                                ║"
    echo "$FORBIDDEN_FILES" | while read -r f; do echo "║    $f"; done
    echo "║                                                          ║"
    echo "║  Para implementar em hono/jsx, use branch ui/*           ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
fi

# ── Block prototype HTML files in project root ─────────────────────────────
ROOT_PROTOTYPES=$(echo "$STAGED_FILES" | grep -E '^prototype-.*\.html$' | grep -vE '^[[:space:]]*$')
if [ -n "$ROOT_PROTOTYPES" ]; then
  echo ""
  echo "⚠️  Prototipos HTML detectados na RAIZ do projeto:"
  echo "$ROOT_PROTOTYPES" | while read -r f; do echo "   $f"; done
  echo ""
  echo "   Mova para prototypes/ — ex: prototypes/home-redesign.html"
  echo "   E crie o template de intencoes: prototypes/home-redesign.md"
  echo ""
  exit 1
fi

exit 0
