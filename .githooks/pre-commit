#!/bin/bash
# Pre-commit hook: blocks commits to main/master and runs basic checks.
# Install: git config core.hooksPath .githooks

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# ── Block direct commits to main ────────────────────────────────────────────
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  ❌  BLOQUEADO: Commit direto na branch '$BRANCH'       ║"
  echo "║                                                          ║"
  echo "║  Crie uma branch antes de commitar:                      ║"
  echo "║    git checkout -b feat/minha-feature                    ║"
  echo "║    git checkout -b fix/meu-fix                           ║"
  echo "║    git checkout -b ui/minha-mudanca                      ║"
  echo "║                                                          ║"
  echo "║  Depois faça PR para main.                               ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ── Block commits with .env or secrets ──────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only)

if echo "$STAGED_FILES" | grep -qE '\.env$|\.env\.local|\.env\.production|\.env\.staging'; then
  echo ""
  echo "❌  BLOQUEADO: Tentativa de commitar arquivo .env"
  echo "   Arquivos .env contêm secrets e NÃO devem ser commitados."
  echo ""
  exit 1
fi

# ── Enforce branch naming convention ────────────────────────────────────────
if ! echo "$BRANCH" | grep -qE '^(feat|fix|ui|chore|docs|refactor|test)/'; then
  echo ""
  echo "⚠️  Branch '$BRANCH' não segue a convenção."
  echo "   Use: feat/, fix/, ui/, chore/, docs/, refactor/, test/"
  echo "   Exemplo: ui/melhorar-home-page"
  echo ""
  # Warning only, not blocking
fi

exit 0
