{
  "name": "@acdg/social-care-bff",
  "version": "0.0.0",
  "exports": "./src/server.ts",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read src/server.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/server.ts",
    "check": "deno check src/**/*.ts src/**/*.tsx",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@hono/hono"
  },
  "exclude": [
    "contracts/",
    "handbook/",
    "static/",
    "cov_profile/",
    "coverage/"
  ]
}
