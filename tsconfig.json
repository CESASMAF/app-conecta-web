{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vinxi/types/client", "node", "bun"],

    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "tests", "app.config.ts"],
  "exclude": ["node_modules", ".output", ".vinxi", ".nitro", "handbook", "specs"]
}
